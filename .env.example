# AuditScan IA — Environment variables
# Copy this file: cp .env.example .env

# ---- Deployment ----
REGISTRY_OWNER=
IMAGE_TAG=latest

# ---- PostgreSQL ----
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=
DATABASE_URL=

# ---- Redis ----
REDIS_PASSWORD=
REDIS_URL=

# ---- Security / JWT ----
SECRET_KEY=
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ---- External APIs ----
SHODAN_API_KEY=
VIRUSTOTAL_API_KEY=
ABUSEIPDB_API_KEY=

# ---- AI Analysis ----
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
AI_ANALYSIS_ENABLED=true
AI_MODEL=

# ---- Frontend ----
FRONTEND_URL=
CORS_ORIGINS=
NEXT_PUBLIC_API_URL=
NEXT_PUBLIC_WS_URL=
INTERNAL_API_URL=
