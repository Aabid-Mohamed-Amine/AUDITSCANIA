# ============================================================
# AuditScan IA — Environment Variables Template
# Copier vers .env et remplir les valeurs réelles.
# Ne jamais commiter .env.
# ============================================================

# ---- Déploiement (docker-compose.prod.yml uniquement) ----
REGISTRY_OWNER=DEVLOPPER17
IMAGE_TAG=latest

# ---- PostgreSQL ----
POSTGRES_USER=auditscan
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=auditscan_db
DATABASE_URL=postgresql://auditscan:change_me_strong_password@postgres:5432/auditscan_db

# ---- Redis ----
# Laisser vide en dev (pas d'auth). Obligatoire en prod.
REDIS_PASSWORD=
REDIS_URL=redis://redis:6379/0

# ---- Security / JWT ----
# Générer avec : openssl rand -hex 32
SECRET_KEY=
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ---- External APIs ----
SHODAN_API_KEY=
VIRUSTOTAL_API_KEY=
ABUSEIPDB_API_KEY=

# ---- Frontend ----
FRONTEND_URL=http://localhost:3001
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000
